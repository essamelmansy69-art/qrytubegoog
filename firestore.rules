rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all safety gate
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidQRCode(data) {
      return data.id is string && data.id.size() <= 128 && data.id.matches('^[a-zA-Z0-9_\\-]+$')
        && data.originalUrl is string && data.originalUrl.size() <= 2048
        && data.targetUrl is string && data.targetUrl.size() <= 2048
        && data.platform is string && data.platform.size() <= 50
        && data.scans is number && data.scans >= 0;
    }

    match /qrcodes/{qrcodeId} {
      // Allow gets (reads single document for redirection)
      allow get: if isValidId(qrcodeId);
      
      // Allow create (public users creating a new QR code)
      allow create: if isValidId(qrcodeId)
        && isValidQRCode(incoming())
        && incoming().scans == 0
        && incoming().id == qrcodeId;

      // Allow update (increment scans count only)
      allow update: if isValidId(qrcodeId)
        && isValidQRCode(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['scans'])
        && incoming().scans == existing().scans + 1;
    }
  }
}
